# Copy to .env and fill in, or export in your shell.

# --- Option A (default): OpenRouter free tier -------------------------------
# 1. Sign up free at https://openrouter.ai, create a key.
# 2. Pick a CURRENT free model at https://openrouter.ai/collections/free-models
#    (free models appear/disappear without warning — verify before running!)
COURSE_API_KEY=sk-or-v1-...
COURSE_BASE_URL=https://openrouter.ai/api/v1
COURSE_MODEL=openai/gpt-oss-120b:free

# --- Option B: Groq free tier ------------------------------------------------
# COURSE_API_KEY=gsk_...
# COURSE_BASE_URL=https://api.groq.com/openai/v1
# COURSE_MODEL=qwen/qwen3-32b        # check https://console.groq.com/docs/models

# --- Option C: Ollama, 100% free & local -------------------------------------
# COURSE_API_KEY=ollama
# COURSE_BASE_URL=http://localhost:11434/v1
# COURSE_MODEL=qwen3:8b              # after: ollama pull qwen3:8b

# Seconds to sleep between API calls (free tiers are rate-limited;
# OpenRouter free ≈ 20 req/min and 200 req/day):
COURSE_SLEEP=3.5

# Comma-separated fallback models — auto-rotation on repeated 429 or 404:
COURSE_FALLBACK_MODELS=nvidia/nemotron-3-super-120b-a12b:free,z-ai/glm-4.5-air:free,moonshotai/kimi-k2.6:free,google/gemma-4-31b-it:free
