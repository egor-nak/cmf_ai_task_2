# Copy to .env and fill in your real key. The runner loads .env automatically.
# NEVER put real keys in THIS file — .env.example is committed to git; .env is not.

# --- Option 0: Qwen via Alibaba Cloud Model Studio (DashScope) -----------------
# Key: https://modelstudio.console.alibabacloud.com → API-KEY page.
# New accounts get free trial token quotas; qwen-plus is the quality pick,
# qwen-flash the cheap one. The runner sends enable_thinking=false so Qwen3
# reasoning can't leak. China-mainland accounts use
# https://dashscope.aliyuncs.com/compatible-mode/v1 instead.
# COURSE_API_KEY=sk-your_key_here
# COURSE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# COURSE_MODEL=qwen-plus
# COURSE_FALLBACK_MODELS=qwen-flash
# COURSE_SLEEP=1.5

# --- Option A (recommended): Groq free tier -----------------------------------
# Key from https://console.groq.com. llama-3.3-70b-versatile is non-reasoning
# (no chain-of-thought to leak) and allows ~30 req/min, ~1,000 req/day free.
COURSE_API_KEY=rk_live_your_key_here
COURSE_BASE_URL=https://api.ranvik.ru/v1
COURSE_MODEL=deepseek-v4-flash
COURSE_FALLBACK_MODELS=deepseek-v4-flash
COURSE_SLEEP=2.5

# --- Option B: OpenRouter free tier -------------------------------------------
# Key from https://openrouter.ai. Only ~50 free-model req/day (~1,000/day after
# a one-time $10 credit purchase). Pick a CURRENT free model at
# https://openrouter.ai/collections/free-models — IDs churn without warning.
# COURSE_API_KEY=sk-or-v1-your_key_here
# COURSE_BASE_URL=https://openrouter.ai/api/v1
# COURSE_MODEL=openai/gpt-oss-120b:free
# COURSE_FALLBACK_MODELS=nvidia/nemotron-3-super-120b-a12b:free,z-ai/glm-4.5-air:free
# COURSE_SLEEP=3.5

# --- Option C: Ollama, 100% free & local, no limits ---------------------------
# COURSE_API_KEY=ollama
# COURSE_BASE_URL=http://localhost:11434/v1
# COURSE_MODEL=qwen3:8b              # after: ollama pull qwen3:8b

# Optional knobs:
# COURSE_HISTORY_WINDOW=60   # dialogue messages sent per call (token cap safety)
# COURSE_MAX_TOKENS=900      # default per-completion cap
